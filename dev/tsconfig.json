{
    "extends": "../tsconfig.json",
    "exclude": [],
    "include": [
        "**/*.js",
        "**/*.jsx",
        "**/*.mjs",
        "**/*.cjs",
        "**/*.ts",
        "**/*.tsx",
        "../src/**/*.ts",
        "../src/**/*.tsx",
        "next.config.mjs",
        ".next/types/**/*.ts",
    ],
    "compilerOptions": {
        "baseUrl": "./",
        "paths": {
            "@payload-config": ["./payload.config.ts"],
            "payload-ai-plugin": ["../src/index.ts"],
            "payload-ai-plugin/client": ["../src/exports/client.ts"],
            "payload-ai-plugin/rsc": ["../src/exports/rsc.ts"],
        },
        "noEmit": true,
        "emitDeclarationOnly": false,
    },
}
